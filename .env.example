# asset-tracker — example env. Copy to .env and fill in.
AT_DB_PATH=./data/asset-tracker.db
AT_LOG_LEVEL=INFO
AT_BACKUP_KEEP=7

# Optional integrations — system runs on local data even if these are empty.
# Used by Sprint 9 extensibility stubs (no live calls in this loop).
AT_STRIPE_API_KEY=
AT_GUMROAD_ACCESS_TOKEN=
AT_GITHUB_TOKEN=
