# asset-tracker — example env. Copy to .env and fill in.
AT_DB_PATH=./data/asset-tracker.db
AT_LOG_LEVEL=INFO
AT_BACKUP_KEEP=7

# Enable live platform imports (default off for safety)
AT_LIVE_INTEGRATIONS=0

# Platform API keys — only needed when AT_LIVE_INTEGRATIONS=1
AT_STRIPE_API_KEY=
AT_GUMROAD_ACCESS_TOKEN=
AT_GITHUB_TOKEN=
AT_BANDCAMP_FAN_TOKEN=
AT_ETSY_API_KEY=
AT_ETSY_SHOP_ID=
